<?xml version="1.0"?>
<queryDef xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="s_rh_fk_concepto" rem="" columns="sys_pk:Int,sys_timestamp:DateTime,sys_guid:String,sys_dtcreated:DateTime,sys_user:String,sys_lastuser:String,sys_exported:Bool,sys_dtexported:DateTime,sys_info:String,sys_recver:Int,sys_deleted:Bool,sys_lock:Int,codigo:String,descripcion:String,notas:String,formula:String,tipo:Int,gravable:Bool,especie:Bool,sat_elemento:Int,sat_clave:String,cuenta_contable:String,contra_cuenta:String,tipo_asiento:Int,ref_tiponomina:Int,manual:Bool,polizadetallada:Bool" parameters="text:String,p_tipo:Int" permission="" xmlns="http://dev.induxsoft.net/xsd/querydef.xsd">
  <sql engine="MY_SQL">select * from rh_concepto_nomina 
	where (codigo like concat('%',@text,'%') or descripcion like concat('%',@text,'%')) and  if (isnull(@p_tipo),true,tipo=@p_tipo) 
