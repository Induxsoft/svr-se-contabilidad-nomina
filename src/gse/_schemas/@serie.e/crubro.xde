<?xml version="1.0"?>
<lxmd xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://dev.induxsoft.net/xsd/xde.xsd">
  <entity name="crubro" readonly="false">
    <entity_description />
    <field name="Codigo" required="true" unique="false" type="String" precision="0" scale="0" size="20" tablefield="Codigo">
      <field_description />
    </field>
    <field name="Color" required="false" unique="false" type="Int" precision="0" scale="0" size="0" tablefield="Color">
      <field_description />
    </field>
    <field name="Descripcion" required="true" unique="false" type="String" precision="0" scale="0" size="100" tablefield="Descripcion">
      <field_description />
    </field>
    <field name="Notas" required="false" unique="false" type="String" precision="0" scale="0" size="99999999" tablefield="Notas">
      <field_description />
    </field>
  </entity>
</lxmd>