CREATE OR REPLACE VIEW qryuserprofile AS select tuser.userid AS userid,profile.item AS item,sitem.description AS description,sitem.itemid AS itemid from (sitem join (tuser join (user_usergroup_ join profile on((user_usergroup_.groups = profile.usergroup))) on((tuser.sys_pk = user_usergroup_.users))) on((sitem.sys_pk = profile.item))) group by tuser.userid,profile.item,sitem.description,sitem.itemid