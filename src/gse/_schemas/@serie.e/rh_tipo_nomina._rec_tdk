#def table(name) "table"
#def col(name, type, caption) "column"
#pattern col "'$name':'$type'"
#pattern col "'$name':'$type' ['@caption']"

table("rh_tipo_nomina")
{
	columns
	{
		sys_pk : Int ["sys_pk"]
		sys_timestamp : DateTime ["sys_timestamp"]
		sys_guid : String ["sys_guid"]
		sys_dtcreated : DateTime ["sys_dtcreated"]
		sys_user : String ["sys_user"]
		sys_lastuser : String ["sys_lastuser"]
		sys_exported : Bool ["sys_exported"]
		sys_dtexported : DateTime ["sys_dtexported"]
		sys_info : String ["sys_info"]
		sys_recver : Int ["sys_recver"]
		sys_deleted : Bool ["sys_deleted"]
		sys_lock : Int ["sys_lock"]
		nombre : String ["nombre"]
		dias : Decimal ["dias"]
		sat_tiponomina : String ["sat_tiponomina"]
		sat_periodicidad : String ["sat_periodicidad"]
		ref_grupo_conceptos : Int ["ref_grupo_conceptos"]
		sel_manual_empleados : Bool ["sel_manual_empleados"]
		var_general : String ["var_general"]
		var_empleado : String ["var_empleado"]
	}
