CREATE OR REPLACE VIEW qrygroupprofile AS select profile.sys_pk AS sys_pk,profile.sys_timestamp AS sys_timestamp,profile.sys_guid AS sys_guid,profile.sys_dtcreated AS sys_dtcreated,profile.sys_user AS sys_user,profile.sys_lastuser AS sys_lastuser,profile.sys_exported AS sys_exported,profile.sys_dtexported AS sys_dtexported,profile.sys_info AS sys_info,profile.item AS item,profile.usergroup AS usergroup,usergroup.groupid AS groupid,sitem.description AS description,sitem.itemid AS itemid from (usergroup join (sitem join profile on((sitem.sys_pk = profile.item))) on((usergroup.sys_pk = profile.usergroup)))