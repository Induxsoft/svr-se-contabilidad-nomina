#include "dkli.dkh"
#!
module ""
{
     @NIC=""//solo para v12

     @jg="gse"
     @program="createdb.dkl"
     @status_job_solicitado=0
     @bd_prefix="se_@uuid"
	@app="serie.e"
     @usehashmd5unicode=@true
     @name_bd_v12="Nomina v12"
     @name_bd_conta_v12="Contabilidad v12"

     @_QNAME="epifania@Induxsoft"
     @_PREFIXBD_CNNS="Connections@Induxsoft/"
