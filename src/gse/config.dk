     @path_log="_log"
     
     //esto aplica si la var @_settings_var_gloval =false
     new @_settings
     {
          @"Engine": "MY_SQL"
          @"Host": "localhost"
          @"UserName": "root"
          @"Password":""
          @"Port": 3306
          @"DefaultSchema": ""
          @"SSLMode": 0
     }
}


