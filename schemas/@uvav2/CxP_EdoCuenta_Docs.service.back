<?xml version="1.0"?>
<queryDef xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="CxP_EdoCuenta_Docs" rem="" columns="rfc_receptor:String,UUID:String,Emision:String,Referencia:String,Total:Decimal,Pagos:Decimal,Saldo:Decimal,Divisa:String,SaldoMXN:Decimal,TipoCambio:Decimal" parameters="rfc_emisor:String, rfc_receptor:String" permission="" xmlns="http://dev.induxsoft.net/xsd/querydef.xsd">
  <sql engine="MY_SQL">Select uuid as UUID, emision as Emision, referencia as Referencia, total as Total, IFNULL((ImpPagado),0) AS Pagos, (total - ifnull((ImpPagado),0)) as Saldo, divisa as Divisa, total - ifnull(ImpPagado,0) AS SaldoMXN, TipoCambio  from ts_cfdi left join ts_rel_pago on ts_cfdi.uuid=ts_rel_pago.IdPago where ((MetodoPago='PPD' and Tipo=0) or (UsoCFDI='G02' and(TipoRelacionCFDIPrevios='01' or TipoRelacionCFDIPrevios='02') and tipo=1)) and rfc_emisor=@rfc_receptor and not MetodoPago='PUE' and cancelacion is null order by uuid;</sql>
</queryDef>