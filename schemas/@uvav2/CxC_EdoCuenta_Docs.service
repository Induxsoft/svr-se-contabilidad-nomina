<?xml version="1.0"?>
<queryDef xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="CxC_EdoCuenta_Docs" rem="" columns="rfc_receptor:String,UUID:String,Emision:String,Referencia:String,Total:Decimal,Pagos:Decimal,Saldo:Decimal,Divisa:String,SaldoMXN:Decimal,TipoCambio:Decimal" parameters="rfc_emisor:String,rfc_receptor:String,divisa:String" permission="" xmlns="http://dev.induxsoft.net/xsd/querydef.xsd">
  <sql engine="MY_SQL">Select uuid as UUID, emision as Emision, referencia as Referencia, total as Total, IFNULL(ImpPagado,0) AS Pagos, (total - (IFNULL(ImpPagado,0)+IFNULL(notasnc.Aplicado,0))) as Saldo, divisa as Divisa, total - (IFNULL(ImpPagado,0)+IFNULL(notasnc.Aplicado,0)) AS SaldoMXN,IFNULL(notasnc.Aplicado,0) as notascredito,TipoCambio  from ts_cfdi left join (select idDocumento, sum(ImpPagado) ImpPagado from ts_rel_pago inner join ts_cfdi on ts_cfdi.uuid=ts_rel_pago.idPago  where ts_cfdi.cancelacion is null group by idDocumento)  ts_rel_pago on ts_cfdi.uuid=ts_rel_pago.IdDocumento Left join (select IdDocumento as Doc,sum(ImpAplicado) as Aplicado  from ts_rel_fac where ImpAplicado >0 group by IdDocumento) notasnc on notasnc.Doc = uuid where ((MetodoPago='PPD' and Tipo=0) or (UsoCFDI='G02' and(TipoRelacionCFDIPrevios='01' or TipoRelacionCFDIPrevios='02') and tipo=1)) and rfc_receptor=@rfc_receptor and not MetodoPago='PUE' and cancelacion is null and divisa=@divisa order by uuid;</sql>
</queryDef>