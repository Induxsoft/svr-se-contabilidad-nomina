<?xml version="1.0"?>
<queryDef xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="cti_info" rem="ID y Pwd de la CTI configurada" columns="id:String,pwd:String" parameters="" permission="" xmlns="http://dev.induxsoft.net/xsd/querydef.xsd">
  <sql engine="MY_SQL">
  select ifnull((select varvalue from configuraciones where varname='FXCuentaCFDI'),'') id, ifnull((select varvalue from configuraciones where varname='FXPWDCuentaCFDI'),'') pwd;
</sql>
</queryDef>