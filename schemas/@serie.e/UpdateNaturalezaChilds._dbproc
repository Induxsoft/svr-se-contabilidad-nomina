CREATE DEFINER=`root`@`%` PROCEDURE `UpdateNaturalezaChilds`(in pk int)
BEGIN
    DECLARE Naturazela INT DEFAULT NULL;
    DECLARE Hijo INT DEFAULT NULL;
    DECLARE NumHijos INT DEFAULT 0;
    DECLARE Contador INT DEFAULT 0;
    DECLARE Hijos CURSOR FOR SELECT sys_pk FROM ccontable WHERE icuenta = pk;
	SET NumHijos = (SELECT count(sys_pk) FROM ccontable WHERE icuenta = pk);
    SET Naturazela = (SELECT tipo FROM ccontable WHERE sys_pk = pk);
    IF(NumHijos > 0)
      THEN
        OPEN Hijos;
        REPEAT
    		FETCH Hijos INTO Hijo;
    			IF(Hijo IS NOT NULL)
					THEN 
						UPDATE ccontable cc SET cc.Tipo = Naturazela WHERE sys_pk = Hijo;
						CALL UpdateNaturalezaChilds(Hijo);
    			END IF;
            SET Contador = Contador + 1;
        UNTIL Contador >=  NumHijos END REPEAT;
        CLOSE Hijos;
	END IF;
END