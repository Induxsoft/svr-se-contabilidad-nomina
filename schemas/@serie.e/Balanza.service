WHEN 3 THEN c.H03
WHEN 4 THEN c.H04
WHEN 5 THEN c.H05
WHEN 6 THEN c.H06
WHEN 7 THEN c.H07
WHEN 8 THEN c.H08
WHEN 9 THEN c.H09
WHEN 10 THEN c.H10
WHEN 11 THEN c.H11
WHEN 12 THEN c.H12
WHEN 13 THEN c.HFinal
WHEN 14 then SUM(d.haber)
ELSE 0
END as 'haber',
CASE @periodo
WHEN 1 THEN c.S01
WHEN 2 THEN c.S02
WHEN 3 THEN c.S03
WHEN 4 THEN c.S04
WHEN 5 THEN c.S05
WHEN 6 THEN c.S06
WHEN 7 THEN c.S07
WHEN 8 THEN c.S08
WHEN 9 THEN c.S09
WHEN 10 THEN c.S10
WHEN 11 THEN c.S11
WHEN 12 THEN c.S12
WHEN 13 THEN c.SFinal
WHEN 14 THEN c.SFinal
END as 'sfinal' FROM ccontable c LEFT JOIN cdpoliza d on d.ICuenta = c.sys_pk LEFT JOIN cpoliza p ON d.FK_Cpoliza_Detalle = p.sys_pk WHERE (
CASE @periodo
WHEN 1 THEN c.S01
WHEN 2 THEN c.S02
WHEN 3 THEN c.S03
WHEN 4 THEN c.S04
WHEN 5 THEN c.S05
WHEN 6 THEN c.S06
WHEN 7 THEN c.S07
WHEN 8 THEN c.S08
WHEN 9 THEN c.S09
WHEN 10 THEN c.S10
WHEN 11 THEN c.S11
WHEN 12 THEN c.S12
WHEN 13 THEN c.SFinal
WHEN 14 THEN c.SFinal
END
)  AND p.Periodo &lt; @periodo AND p.Aplicada = true GROUP BY c.Codigo, c.Descripcion ORDER BY c.codigo);
</sql>
</queryDef>