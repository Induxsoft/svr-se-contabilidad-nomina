<?xml version="1.0"?>
<queryDef xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="s_rh_empleados" rem="" columns="sys_pk:Int,sys_timestamp:DateTime,sys_guid:String,sys_dtcreated:DateTime,sys_user:String,sys_lastuser:String,sys_exported:Bool,sys_dtexported:DateTime,sys_info:String,sys_recver:Int,sys_deleted:Bool,sys_lock:Int,codigo:String,nombre:String,apellido1:String,apellido2:String,rfc:String,curp:String,fnacimiento:DateTime,fingreso:DateTime,fcontratacion:DateTime,nss:String,sat_regimenfiscal:String,foto:String,factualizacionfoto:DateTime,nacionalidad:String,edocivil:Int,conyuge:String,depeconomicos:Int,hijos:Int,pension:Bool,ingresonecesario:Decimal,tipovivienda:Int,gastofamiliarmensual:Decimal,aportaciongasto:Decimal,fechaestudiosocioe:DateTime,escolaridad:Int,titulos:String,competencias:String,estrellas:Int,cerebros:Int,focos:Int,tachas:Int,notas:String,totalmiembrosfam:Int,obs_socio:String,ref_categoria:Int" parameters="text:String" permission="" xmlns="http://dev.induxsoft.net/xsd/querydef.xsd">
  <sql engine="MY_SQL">select e.* from rh_empleado_org e where if(isnull(@text),true, e.apellido1 like concat('%',@text,'%') or e.apellido2 like concat('%', @text,'%') or e.nombre like concat('%', @text,'%') or e.rfc like concat('%',@text,'%') or e.nss like concat('%',@text,'%') or e.curp like concat('%',@text,'%') or e.codigo like concat('%',@text,'%')  ) order by e.apellido1, e.apellido2, e.nombre;</sql>
</queryDef>